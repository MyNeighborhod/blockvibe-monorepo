# Copy to .env.staging before deploying staging:
#   cp .env.staging.example .env.staging

# Must match apps/payload-web/.env.staging (enqueue token mint + verify)
EMAIL_SERVICE_SIGNING_SECRET=7c9e8f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e

# SMTP Configuration (AWS SES credentials for staging)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_STAGING_SES_SMTP_USERNAME_HERE
SMTP_PASS=YOUR_STAGING_SES_SMTP_PASSWORD_HERE
SMTP_FROM_ADDRESS=info@blockvibe.org
SMTP_FROM_NAME="BlockVibe Staging"

# Must match payload-web PAYLOAD_SECRET in staging
PAYLOAD_SECRET=7c9e8f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e
