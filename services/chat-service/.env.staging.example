# Copy to .env.staging before deploying staging:
#   cp .env.staging.example .env.staging

# Must match apps/payload-web/.env.staging (JWT token sign + verify)
CHAT_SERVICE_SIGNING_SECRET=7c9e8f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e

# Local documentation folder path (nested inside Lambda deployment bundle)
DOCS_DIR=./docs

# Staging API Keys
CURSOR_GENERAL_API_KEY=your-staging-cursor-api-key
GEMINI_GENERAL_API_KEY=your-staging-gemini-api-key
