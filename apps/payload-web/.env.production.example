# Copy to .env.production before your first deploy:
#   cp .env.production.example .env.production
#
# deploy.sh uploads this file to the server as /home/ubuntu/app/.env

# Used by docker-compose for the Postgres container and Payload at runtime
DB_USER=postgres
DB_PASSWORD=change-me-to-a-long-random-string
DB_NAME=blockvibe-multitenant

# Overridden at runtime by docker-compose to point at the db container
DATABASE_URL=postgres://postgres:change-me-to-a-long-random-string@db:5432/blockvibe-multitenant

# Used to encrypt JWT tokens (generate: openssl rand -hex 32)
PAYLOAD_SECRET=change-me

# Public URL of the site — must match your domain (HTTPS)
NEXT_PUBLIC_SERVER_URL=https://info.blockvibe.org

# Used to authenticate cron jobs (generate: openssl rand -hex 16)
CRON_SECRET=change-me

# Used to validate preview requests (generate: openssl rand -hex 16)
PREVIEW_SECRET=change-me

# SMTP Mail Server Configuration (AWS SES)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_SES_SMTP_USERNAME_HERE
SMTP_PASS=YOUR_SES_SMTP_PASSWORD_HERE
SMTP_FROM_ADDRESS=info@blockvibe.org
SMTP_FROM_NAME=BlockVibe

